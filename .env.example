# Copy to a protected host-only environment file. Do not commit its populated copy.
# Bootstrap settings read by the current application code.
QASAWATCH_DATABASE=/var/lib/qasawatch/qasawatch.db
QASAWATCH_LOG_LEVEL=INFO

# Secret values are intentionally not read from this file by configuration alone.
# Store only references such as `env:QASAWATCH_GOOGLE_MAPS_API_KEY` in watcher
# configuration, then provide the referenced variables to the service process.
QASAWATCH_GOOGLE_MAPS_API_KEY=replace-me
# Either compact service-account JSON or an absolute path to a protected JSON key file.
QASAWATCH_GOOGLE_SERVICE_ACCOUNT_JSON=/etc/qasawatch/google-service-account.json
QASAWATCH_DISCORD_WEBHOOK_URL=replace-me
QASAWATCH_SMTP_USERNAME=replace-me
QASAWATCH_SMTP_PASSWORD=replace-me
