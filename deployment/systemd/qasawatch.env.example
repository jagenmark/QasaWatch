# Install as /etc/qasawatch/qasawatch.env, mode 0600, owned by qasawatch.
# The unit reads this file without shell expansion: use literal values only.
QASAWATCH_DATABASE=/var/lib/qasawatch/qasawatch.db
QASAWATCH_LOG_LEVEL=INFO
# Optional: full path to Chrome/Chromium when it is not in a standard location.
# QASAWATCH_CHROME_EXECUTABLE=/usr/bin/google-chrome

# Values below are placeholders. The current code resolves secret references of
# the form env:VARIABLE_NAME; do not put those references here as their values.
QASAWATCH_GOOGLE_MAPS_API_KEY=replace-me
# Either compact service-account JSON or an absolute path to a protected JSON key file.
QASAWATCH_GOOGLE_SERVICE_ACCOUNT_JSON=/etc/qasawatch/google-service-account.json
QASAWATCH_DISCORD_WEBHOOK_URL=replace-me
QASAWATCH_SMTP_USERNAME=replace-me
QASAWATCH_SMTP_PASSWORD=replace-me
